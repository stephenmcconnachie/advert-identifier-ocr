#!/usr/bin/env python3
"""Ad Break Pipeline - Coordinates metadata extraction, OCR detection, and clip extraction.

This script automates the full pipeline:
1. Extract metadata from CSV → JSON
2. OCR-based advert detection (5 FPS frame extraction + PaddleOCR-VL)
3. Extract individual advert clips (lossless)
4. Generate summary report

Usage:
    advert-identifier-pipeline --input-folder /path/to/videos --csv-folder /path/to/csv/files
"""

import argparse
import json
import logging
import os
import subprocess
import sys
import time
import xml.etree.ElementTree as ET
from datetime import datetime
from pathlib import Path
from typing import Dict, List, Optional, Tuple


def timecode_to_seconds(timecode: str) -> float:
    """Convert HH:MM:SS timecode to seconds.

    Args:
        timecode: Timecode string in HH:MM:SS format.

    Returns:
        Total seconds as float.
    """
    parts = timecode.strip().split(":")
    if len(parts) == 3:
        hours, minutes, seconds = parts
        return int(hours) * 3600 + int(minutes) * 60 + float(seconds)
    elif len(parts) == 2:
        minutes, seconds = parts
        return int(minutes) * 60 + float(seconds)
    else:
        raise ValueError(f"Invalid timecode format: {timecode}")


def setup_logging(log_level: str = "INFO") -> logging.Logger:
    """Configure logging."""
    logging.basicConfig(
        level=getattr(logging, log_level.upper()),
        format='%(asctime)s - %(levelname)s - %(message)s',
        handlers=[logging.StreamHandler()]
    )
    return logging.getLogger(__name__)


def create_parser() -> argparse.ArgumentParser:
    """Create CLI argument parser."""
    parser = argparse.ArgumentParser(
        description="Coordinate ad break processing pipeline"
    )
    
    parser.add_argument(
        "--input-folder",
        type=str,
        default=os.environ.get("INPUT_FOLDER"),
        help="Path to folder containing .mp4 files (env: INPUT_FOLDER)"
    )
    parser.add_argument(
        "--csv-folder",
        type=str,
        default=os.environ.get("CSV_FOLDER"),
        help="Path to folder containing CSV files, format YYYY-MM-DD_CHANNEL.csv (env: CSV_FOLDER)"
    )
    parser.add_argument(
        "--log-level",
        type=str,
        choices=["DEBUG", "INFO", "WARNING", "ERROR"],
        default="INFO",
        help="Logging level (default: INFO)"
    )
    parser.add_argument(
        "--verbose",
        action="store_true",
        help="Show detailed progress information during sub-commands"
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Preview what would be processed without executing"
    )
    parser.add_argument(
        "--before-secs",
        type=float,
        default=10.0,
        help="Seconds before ad break timecode to include in frame extraction (default: 10)"
    )
    parser.add_argument(
        "--after-secs",
        type=float,
        default=360.0,
        help="Seconds after ad break timecode to include in frame extraction (default: 360)"
    )
    parser.add_argument(
        "--fps",
        type=float,
        default=5.0,
        help="Frame extraction rate for OCR detection (default: 5)"
    )
    parser.add_argument(
        "--ocr-endpoint",
        type=str,
        default="http://localhost:8000/v1/chat/completions",
        help="vLLM OCR endpoint URL (default: http://localhost:8000/v1/chat/completions)"
    )
    parser.add_argument(
        "--ocr-model",
        type=str,
        default="PaddlePaddle/PaddleOCR-VL",
        help="OCR model name (default: PaddlePaddle/PaddleOCR-VL)"
    )
    return parser


def get_video_duration(video_path: Path) -> float:
    """Get video duration in seconds using ffprobe."""
    try:
        result = subprocess.run(
            [
                "ffprobe",
                "-v", "error",
                "-show_entries", "format=duration",
                "-of", "default=noprint_wrappers=1:nokey=1",
                str(video_path)
            ],
            capture_output=True,
            text=True,
            check=True
        )
        return float(result.stdout.strip())
    except (subprocess.CalledProcessError, ValueError) as e:
        logging.warning(f"Could not determine duration for {video_path}: {e}")
        return 0.0


def run_metadata_extractor(video_path: Path, csv_folder: Path, output_dir: Path, 
                           before_secs: float, logger: logging.Logger) -> Tuple[bool, Optional[Path]]:
    """Run advert-identifier-metadata-extract to generate JSON from video and CSV folder."""
    json_path = output_dir / f"{video_path.stem}_metadata.json"
    
    bin_dir = Path(__file__).parent
    
    cmd = [
        sys.executable,
        str(bin_dir / "advert-identifier-metadata-extract"),
        "--video", str(video_path),
        "--csv-folder", str(csv_folder),
        "--output-dir", str(output_dir),
        "--before-secs", str(before_secs),
    ]
    
    logger.info(f"Running metadata extractor: {' '.join(cmd)}")
    
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        logger.info(f"Metadata extracted: {json_path}")
        return True, json_path
    except subprocess.CalledProcessError as e:
        logger.error(f"Metadata extraction failed: {e.stderr}")
        return False, None


def get_ad_break_count(json_path: Path) -> int:
    """Read metadata JSON and return the number of ad breaks."""
    with open(json_path) as f:
        data = json.load(f)
    return len(data.get("ad_breaks", []))


def run_advert_identifier(
    video_url: str,
    json_path: Path,
    ad_break_index: int,
    before_secs: float,
    after_secs: float,
    fps: float,
    ocr_endpoint: str,
    ocr_model: str,
    logger: logging.Logger,
    verbose: bool = False,
) -> Tuple[bool, Optional[Path], int]:
    """Run advert-identifier (OCR detection) on the original video.
    
    Args:
        video_url: Full URL to the original video file.
        json_path: Path to metadata JSON.
        ad_break_index: 0-based index of the ad break.
        before_secs: Seconds before ad break start for frame extraction.
        after_secs: Seconds after ad break start for frame extraction.
        fps: Frame extraction rate.
        ocr_endpoint: vLLM OCR endpoint URL.
        ocr_model: OCR model name.
        logger: Logger instance.
        verbose: Pass --verbose to the identifier.
        
    Returns:
        Tuple of (success, xml_path, advert_count)
    """
    bin_dir = Path(__file__).parent
    
    cmd = [
        sys.executable,
        str(bin_dir / "advert-identifier"),
        "-v", video_url,
        "--metadata-file", str(json_path),
        "--ad-break-index", str(ad_break_index + 1),  # CLI expects 1-based
        "--before-secs", str(before_secs),
        "--after-secs", str(after_secs),
        "--fps", str(fps),
        "--ocr-endpoint", ocr_endpoint,
        "--ocr-model", ocr_model,
    ]

    if verbose:
        cmd.append("--verbose")
    
    logger.info(f"Running OCR detection for ad break {ad_break_index + 1}: {' '.join(cmd)}")
    
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        logger.info(f"OCR detection completed")
        
        # XML is written to same directory as metadata file
        # The detect module uses video stem for the XML filename
        video_stem = Path(video_url.split("?")[0]).stem
        xml_path = json_path.parent / f"{video_stem}.xml"
        advert_count = 0
        
        if xml_path.exists():
            try:
                tree = ET.parse(xml_path)
                root = tree.getroot()
                adverts = root.findall('.//advert')
                advert_count = len(adverts)
                logger.info(f"Found {advert_count} adverts in XML")
            except ET.ParseError as e:
                logger.warning(f"Could not parse XML: {e}")
        else:
            logger.warning(f"Expected XML output not found: {xml_path}")
        
        return True, xml_path, advert_count
    except subprocess.CalledProcessError as e:
        logger.error(f"OCR detection failed: {e.stderr}")
        return False, None, 0


def run_single_advert_clipper(
    xml_path: Path,
    original_video_url: str,
    output_dir: Path,
    json_path: Path,
    ad_break_index: int,
    before_secs: float,
    logger: logging.Logger,
    state_file_path: Path | None = None,
    log_level: str = "INFO",
) -> Tuple[bool, int]:
    """Run advert-identifier-single-advert-clip to extract advert clips.

    Computes clip_offset from JSON metadata to convert clip-relative
    timecodes to broadcast-absolute coordinates.

    Args:
        xml_path: Path to XML with advert analysis results.
        original_video_url: Full URL to the original video file.
        output_dir: Directory where clips will be saved.
        json_path: Path to JSON metadata file (required for clip_offset).
        ad_break_index: 0-based index of the ad break.
        before_secs: Seconds before ad break start used in frame extraction.
        logger: Logger instance.

    Returns:
        Tuple of (success, clip_count).
    """
    bin_dir = Path(__file__).parent

    # Compute clip_offset from JSON metadata
    # clip_offset = (break_start_tod - video_start_tod) - before_secs
    with open(json_path) as f:
        data = json.load(f)

    video_start_secs = timecode_to_seconds(data["video_info"]["start_time"])
    break_start_tod = data["ad_breaks"][ad_break_index]["start_time"]
    break_start_secs = timecode_to_seconds(break_start_tod)
    clip_offset = break_start_secs - video_start_secs - before_secs

    logger.info(
        f"Computed clip_offset: {break_start_tod} - {data['video_info']['start_time']} "
        f"- {before_secs}s = {clip_offset:.3f}s"
    )

    cmd = [
        sys.executable,
        str(bin_dir / "advert-identifier-single-advert-clip"),
        "--xml-file", str(xml_path),
        "--video-url", original_video_url,
        "--json-file", str(json_path),
        "--output-dir", str(output_dir),
        "--clip-offset", str(clip_offset),
    ]

    if state_file_path:
        cmd.extend(["--state-file", str(state_file_path)])
        logger.info(f"Using pipeline state file: {state_file_path}")

    if log_level and log_level != "INFO":
        cmd.extend(["--log-level", log_level])

    logger.info(f"Running advert clip extraction")

    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        clip_count = len(list(output_dir.glob("*.mp4")))
        logger.info(f"Extracted {clip_count} advert clip(s)")
        return True, clip_count
    except subprocess.CalledProcessError as e:
        logger.error(f"Advert clip extraction failed: {e.stderr}")
        return False, 0


def parse_last_advert_info(xml_path: Path) -> Tuple[Optional[str], Optional[str]]:
    """Parse XML to find the last advert's timecode."""
    try:
        tree = ET.parse(xml_path)
        root = tree.getroot()
        
        adverts = root.findall('.//advert')
        if not adverts:
            return None, None
        
        last_advert = adverts[-1]
        timecode = last_advert.find('last_timecode')
        
        if timecode is not None and timecode.text:
            return timecode.text, "timecode"
        
        return None, None
    except Exception as e:
        logging.warning(f"Could not parse last advert from XML: {e}")
        return None, None


def generate_summary(
    results: List[Dict],
    total_runtime: float,
    total_video_duration: float,
    output_path: Path,
    logger: logging.Logger
) -> None:
    """Generate summary report."""
    timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    
    if total_video_duration > 0:
        processing_rate = total_runtime / total_video_duration
    else:
        processing_rate = 0.0
    
    lines = [
        "=" * 80,
        "AD BREAK PIPELINE SUMMARY",
        "=" * 80,
        f"Generated: {timestamp}",
        "",
        f"Total Runtime: {format_duration(total_runtime)}",
        f"Total Video Duration: {format_duration(total_video_duration)}",
        f"Processing Rate: {processing_rate:.2f}s per second of video",
        "",
        "-" * 80,
        "FILES PROCESSED",
        "-" * 80,
        ""
    ]
    
    for i, result in enumerate(results, 1):
        status_icon = "OK" if result['success'] else "FAIL"
        lines.append(f"{i}. {result['filename']}")
        lines.append(f"   - Total Adverts: {result['advert_count']}")
        lines.append(f"   - Total Clips: {result.get('clip_count', 0)}")
        lines.append(f"   - Status: {status_icon} {result['status']}")
        
        if 'ad_breaks' in result and result['ad_breaks']:
            lines.append(f"   - Ad Breaks: {len(result['ad_breaks'])}")
            for break_info in result['ad_breaks']:
                if break_info['success']:
                    clip_info = f", {break_info.get('clip_count', 0)} clips" if break_info.get('clip_count', 0) > 0 else ""
                    lines.append(f"     - Break {break_info['index'] + 1}: {break_info['advert_count']} adverts{clip_info}")
                    if break_info.get('last_time'):
                        lines.append(f"       Last: {break_info['last_time']}")
                else:
                    lines.append(f"     - Break {break_info['index'] + 1}: Failed")
        
        if result['last_advert_time']:
            lines.append(f"   - Last Advert timecode: {result['last_advert_time']}")
        
        if result['error']:
            lines.append(f"   - Error: {result['error']}")
        
        lines.append("")
    
    successful = sum(1 for r in results if r['success'])
    failed = len(results) - successful
    total_adverts = sum(r['advert_count'] for r in results)
    
    lines.extend([
        "-" * 80,
        "SUMMARY STATISTICS",
        "-" * 80,
        "",
        f"Total Files: {len(results)}",
        f"Successful: {successful}",
        f"Failed: {failed}",
        f"Total Adverts Processed: {total_adverts}",
        "",
        "=" * 80
    ])
    
    summary_text = "\n".join(lines)
    
    with open(output_path, 'w') as f:
        f.write(summary_text)
    
    logger.info(f"Summary written to: {output_path}")
    print("\n" + summary_text)


def format_duration(seconds: float) -> str:
    """Format duration in seconds to human readable string."""
    if seconds < 60:
        return f"{seconds:.1f}s"
    elif seconds < 3600:
        minutes = int(seconds // 60)
        secs = int(seconds % 60)
        return f"{minutes}m {secs}s"
    else:
        hours = int(seconds // 3600)
        minutes = int((seconds % 3600) // 60)
        return f"{hours}h {minutes}m"


def main() -> int:
    """Main entry point."""
    parser = create_parser()
    args = parser.parse_args()
    
    if not args.input_folder:
        parser.error("--input-folder is required (or set INPUT_FOLDER env var)")
    if not args.csv_folder:
        parser.error("--csv-folder is required (or set CSV_FOLDER env var)")
    
    logger = setup_logging(args.log_level)
    
    input_folder = Path(args.input_folder)
    csv_folder = Path(args.csv_folder)
    
    if not input_folder.exists():
        logger.error(f"Input folder not found: {input_folder}")
        return 1
    
    if not csv_folder.exists():
        logger.error(f"CSV folder not found: {csv_folder}")
        return 1
    
    mp4_files = sorted(input_folder.glob("*.mp4"))
    
    if not mp4_files:
        logger.warning(f"No .mp4 files found in {input_folder}")
        return 0
    
    logger.info(f"Found {len(mp4_files)} video file(s) to process")
    logger.info(f"Using CSV folder: {csv_folder}")
    logger.info(f"OCR endpoint: {args.ocr_endpoint}")
    logger.info(f"OCR model: {args.ocr_model}")
    logger.info(f"Detection FPS: {args.fps}")
    
    if args.dry_run:
        logger.info("DRY RUN - No actual processing will occur")
        for mp4 in mp4_files:
            logger.info(f"  {mp4.name}")
        return 0
    
    results: List[Dict] = []
    total_video_duration = 0.0
    pipeline_start_time = time.time()
    
    for mp4_file in mp4_files:
        file_start_time = time.time()
        video_name = mp4_file.stem
        
        logger.info(f"\n{'='*60}")
        logger.info(f"Processing: {mp4_file.name}")
        logger.info(f"{'='*60}")
        
        result = {
            'filename': mp4_file.name,
            'success': False,
            'status': 'Not started',
            'advert_count': 0,
            'clip_count': 0,
            'last_advert_time': None,
            'last_advert_type': None,
            'error': None
        }
        
        video_duration = get_video_duration(mp4_file)
        total_video_duration += video_duration
        
        # Step 1: Extract metadata from video + CSV folder
        success, json_path = run_metadata_extractor(
            mp4_file, csv_folder, input_folder, args.before_secs, logger
        )
        if not success:
            result['status'] = 'Failed - Metadata extraction failed'
            result['error'] = 'CSV file not found or metadata extraction error'
            results.append(result)
            continue

        # Derive pipeline state path from metadata JSON
        state_file_path = None
        if json_path:
            stem = json_path.stem
            if stem.endswith("_metadata"):
                stem = stem[:-9]
            candidate = json_path.parent / f"{stem}_pipeline_state.json"
            if candidate.exists():
                state_file_path = candidate
                logger.info(f"Pipeline state file: {state_file_path}")
            else:
                logger.info("No pipeline state file found (stages will write state as they run)")
        
        # Get ad break count from metadata
        if not json_path:
            result['status'] = 'Failed - No metadata JSON'
            result['error'] = 'Metadata extraction produced no JSON file'
            results.append(result)
            continue
            
        num_ad_breaks = get_ad_break_count(json_path)
        if num_ad_breaks == 0:
            logger.warning(f"No ad breaks found in metadata for {video_name}")
            result['status'] = 'Skipped - No ad breaks in metadata'
            results.append(result)
            continue
        
        logger.info(f"Found {num_ad_breaks} ad break(s) in metadata")
        
        # Step 2 + 3: Process each ad break
        original_video_url = str(mp4_file)
        total_adverts = 0
        all_ad_breaks_success = True
        ad_break_results = []
        
        for ad_break_index in range(num_ad_breaks):
            logger.info(f"\nProcessing ad break {ad_break_index + 1}/{num_ad_breaks}")
            
            # Step 2: OCR detection on original video
            success, xml_path, advert_count = run_advert_identifier(
                video_url=original_video_url,
                json_path=json_path,
                ad_break_index=ad_break_index,
                before_secs=args.before_secs,
                after_secs=args.after_secs,
                fps=args.fps,
                ocr_endpoint=args.ocr_endpoint,
                ocr_model=args.ocr_model,
                logger=logger,
                verbose=args.verbose,
            )
            
            if success:
                last_time, last_type = parse_last_advert_info(xml_path)

                # Step 3: Extract individual advert clips
                clips_success, clip_count = run_single_advert_clipper(
                    xml_path=xml_path,
                    original_video_url=original_video_url,
                    output_dir=mp4_file.parent,
                    json_path=json_path,
                    ad_break_index=ad_break_index,
                    before_secs=args.before_secs,
                    logger=logger,
                    state_file_path=state_file_path,
                    log_level=args.log_level,
                )

                ad_break_results.append({
                    'index': ad_break_index,
                    'success': True,
                    'advert_count': advert_count,
                    'last_time': last_time,
                    'last_type': last_type,
                    'clip_count': clip_count if clips_success else 0
                })
                total_adverts += advert_count
                logger.info(f"Ad break {ad_break_index + 1}: Found {advert_count} adverts, extracted {clip_count if clips_success else 0} clips")
            else:
                all_ad_breaks_success = False
                ad_break_results.append({
                    'index': ad_break_index,
                    'success': False,
                    'error': 'OCR detection failed'
                })
                logger.error(f"Ad break {ad_break_index + 1}: Detection failed")
        
        # Update result based on all ad breaks
        if all_ad_breaks_success and ad_break_results:
            result['success'] = True
            result['status'] = f'Success - {len(ad_break_results)} ad break(s)'
            result['advert_count'] = total_adverts
            last_break = ad_break_results[-1]
            result['last_advert_time'] = last_break.get('last_time')
            result['last_advert_type'] = last_break.get('last_type')
            result['ad_breaks'] = ad_break_results
        elif ad_break_results:
            successful_breaks = [b for b in ad_break_results if b['success']]
            result['success'] = len(successful_breaks) > 0
            result['status'] = f'Partial - {len(successful_breaks)}/{len(ad_break_results)} ad breaks'
            result['advert_count'] = total_adverts
            result['ad_breaks'] = ad_break_results
            if successful_breaks:
                result['last_advert_time'] = successful_breaks[-1].get('last_time')
                result['last_advert_type'] = successful_breaks[-1].get('last_type')
        else:
            result['success'] = False
            result['status'] = 'Failed - No ad breaks processed'
            result['error'] = 'All ad break detections failed'
        
        file_runtime = time.time() - file_start_time
        logger.info(f"\nCompleted {mp4_file.name} in {format_duration(file_runtime)}")
        logger.info(f"Total: {len(ad_break_results)} ad break(s), {total_adverts} advert(s)")

        total_clips = sum(b.get('clip_count', 0) for b in ad_break_results if b.get('success'))
        result['clip_count'] = total_clips

        results.append(result)
    
    total_runtime = time.time() - pipeline_start_time
    
    summary_path = input_folder / "advert-identifier-pipeline-summary.txt"
    generate_summary(results, total_runtime, total_video_duration, summary_path, logger)
    
    logger.info(f"\nPipeline completed. Processed {len(results)} files.")
    
    successful_count = sum(1 for r in results if r['success'])
    if successful_count == len(results):
        return 0
    elif successful_count == 0:
        return 1
    else:
        return 2  # Partial success


if __name__ == "__main__":
    sys.exit(main())
