#!/usr/bin/env python3
import json
from openai import OpenAI
client = OpenAI(
    base_url="http://bk-ci-data14.dpi.bfi.org.uk:8000/v1",
    api_key="EMPTY"
)

prompt = '''
This is a video containing two sections:
- a television programme called Lorraine, broadcast on the ITV1 channel
- an advertisement for Disneyland

Your job is to give me a detailed content description / summary of each of those two sections. Do NOT exclude the advertisement summary - make sure to include both.

For each section, please give me ONLY the output in this strict XML format:
<summary>
    <content>the content, with attention to the television genres and conventions being used</content>
    <style>the presentation style, aesthetic choices, etc</style>
    <representation>demographic representation factors such as gender, age, ethnicity, etc. IMPORTANT: don't infer continent of origin, only ethnicity</representation>
</summary>
'''

messages = [
    {
        "role": "user",
        "content": [
            {
                "type": "video_url",
                "video_url": {
                    "url": "http://bk-ci-data14.dpi.bfi.org.uk:1000/2024-03-26_itv1_only/09-00_80_seconds_TIMECODE_OVERLAY.mp4"
                }
            },
            {
                "type": "text",
                "text": prompt
            }
        ]
    }
]

# From Qwen3.5 model card, for testing / fine tuning the quality
'''
Thinking mode for general tasks: temperature=1.0, top_p=0.95, top_k=20, min_p=0.0, presence_penalty=1.5, repetition_penalty=1.0

Thinking mode for precise coding tasks (e.g. WebDev): temperature=0.6, top_p=0.95, top_k=20, min_p=0.0, presence_penalty=0.0, repetition_penalty=1.0

Instruct (or non-thinking) mode for general tasks: temperature=0.7, top_p=0.8, top_k=20, min_p=0.0, presence_penalty=1.5, repetition_penalty=1.0

Instruct (or non-thinking) mode for reasoning tasks: temperature=1.0, top_p=0.95, top_k=20, min_p=0.0, presence_penalty=1.5, repetition_penalty=1.0
'''

# Thinking mode for general tasks
chat_response = client.chat.completions.create(
    #model="Qwen/Qwen3.5-9B",
    model="Qwen/Qwen3.5-4B",
    messages=messages,
    max_tokens=16000,
    temperature=1.0,
    top_p=0.95,
    presence_penalty=1.5,
    extra_body={
        "top_k": 20,
        "min_p": 0.0,
        "repetition_penalty": 1.0,
        "chat_template_kwargs": {"enable_thinking": True},
        "mm_processor_kwargs": {"fps": 0.1, "do_sample_frames": True},
    },
)

'''
# Non-thinking mode for reasoning tasks
chat_response = client.chat.completions.create(
    #model="Qwen/Qwen3.5-9B",
    model="Qwen/Qwen3.5-4B",
    messages=messages,
    max_tokens=2048,
    temperature=1.0,
    top_p=0.95,
    presence_penalty=1.5,
    extra_body={
        "top_k": 20,
        "min_p": 0.0,
        "repetition_penalty": 1.0,
        "chat_template_kwargs": {"enable_thinking": False},
        "mm_processor_kwargs": {"fps": 0.5, "do_sample_frames": True},
    },
)
'''

print(json.dumps(chat_response.model_dump(), indent=2))