#!/usr/bin/env python3
import argparse
import json
import sys
from openai import OpenAI


def main() -> int:
    """Main entry point."""
    parser = argparse.ArgumentParser(
        description="Generate natural language descriptions of video content"
    )
    parser.add_argument(
        "--video",
        required=True,
        help="Video URL to analyze",
    )
    parser.add_argument(
        "--model",
        default="Qwen/Qwen3.5-4B",
        help="Model name (default: Qwen/Qwen3.5-4B)",
    )
    parser.add_argument(
        "--api-base-url",
        default="http://localhost:8000/v1",
        help="vLLM API base URL (default: http://localhost:8000/v1)",
    )
    parser.add_argument(
        "--api-key",
        default="EMPTY",
        help="API key (default: EMPTY)",
    )
    parser.add_argument(
        "--prompt",
        default=None,
        help="Override the built-in prompt",
    )

    parsed_args = parser.parse_args()

    client = OpenAI(base_url=parsed_args.api_base_url, api_key=parsed_args.api_key)

    if parsed_args.prompt:
        prompt = parsed_args.prompt
    else:
        prompt = """This is a video containing two sections:
- a television programme called Lorraine, broadcast on the ITV1 channel
- an advertisement for Disneyland

Your job is to give me a detailed content description / summary of each of those two sections. Do NOT exclude the advertisement summary - make sure to include both.

For each section, please give me ONLY the output in this strict XML format:
<summary>
    <content>the content, with attention to the television genres and conventions being used</content>
    <style>the presentation style, aesthetic choices, etc</style>
    <representation>demographic representation factors such as gender, age, ethnicity, etc. IMPORTANT: don't infer continent of origin, only ethnicity</representation>
</summary>
"""

    messages = [
        {
            "role": "user",
            "content": [
                {
                    "type": "video_url",
                    "video_url": {
                        "url": parsed_args.video
                    }
                },
                {
                    "type": "text",
                    "text": prompt
                }
            ]
        }
    ]

    model = parsed_args.model

    # From Qwen3.5 model card, for testing / fine tuning the quality
    # Thinking mode for general tasks: temperature=1.0, top_p=0.95, top_k=20, min_p=0.0, presence_penalty=1.5, repetition_penalty=1.0
    # Instruct (non-thinking) mode for general tasks: temperature=0.7, top_p=0.8, top_k=20, min_p=0.0, presence_penalty=1.5, repetition_penalty=1.0

    chat_response = client.chat.completions.create(
        model=model,
        messages=messages,
        max_tokens=16000,
        temperature=1.0,
        top_p=0.95,
        presence_penalty=1.5,
        extra_body={
            "top_k": 20,
            "min_p": 0.0,
            "repetition_penalty": 1.0,
            "chat_template_kwargs": {"enable_thinking": True},
            "mm_processor_kwargs": {"fps": 0.1, "do_sample_frames": True},
        },
    )

    print(json.dumps(chat_response.model_dump(), indent=2))
    return 0


if __name__ == "__main__":
    sys.exit(main())
