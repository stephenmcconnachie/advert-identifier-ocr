#!/usr/bin/env python3
"""Post-run analysis report for advert identifier pipeline.

Parses pipeline state JSON files and the pipeline log to generate a
self-contained HTML report with per-break success metrics, unmatched
advert details, weak matches, confidence scores, and anomaly events.

Usage:
    python3 bin/advert-identifier-analysis \\
        --video-dir video/ \\
        --pipeline-log video/pipeline_20260710_163438.log \\
        --output video/pipeline_analysis.html
"""

import argparse
import html
import json
import logging
import os
import re
import sys
from collections import Counter
from datetime import datetime
from pathlib import Path
from xml.etree import ElementTree


def _sanitize_filename(text: str) -> str:
    text = text.replace(" ", "-")
    text = re.sub(r'[\\/:*?"<>|]', "", text)
    return text


logger = logging.getLogger(__name__)

# ── Constants ────────────────────────────────────────────────────────────────

WEAK_TIERS = {"fallback", "advertiser", "estimated", "none", ""}
CLIP_RE = re.compile(r"clips? extracted|Extracted (\d+) advert clip")
NO_MATCH_RE = re.compile(r"NO MATCH.*?\(fallback\)")
ANCHOR_RE = re.compile(r"confidence (\d+\.\d+) < anchor threshold.*running anchor")
ANCHOR_RESULT_RE = re.compile(
    r"confidence after anchor re-estimation: (\d+\.\d+) \(was (\d+\.\d+)\)"
)
CONFIDENCE_RE = re.compile(r"Break (\d+) confidence ([\d.]+)(?: — (.+))?")
CLAMP_RE = re.compile(r"corrected:.*frame (\d+) → (\d+)")
CLAMP_SKIP_RE = re.compile(r"Clamp skipped")
WARNING_RE = re.compile(r"WARNING")
UNMATCHED_LOG_RE = re.compile(r"Unmatched advert (\S+) / (.+?) — logged")


