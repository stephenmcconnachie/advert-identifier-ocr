# ── Data parsing ────────────────────────────────────────────────────────────


def _video_url_from_state(data: dict) -> str:
    """Build a file:// URL from the state's video_info.filepath."""
    fp = data.get("video_info", {}).get("filepath", "")
    if fp:
        resolved = Path(fp).resolve()
        return resolved.as_uri()
    return ""


def _ocr_json_url(video_dir: Path, stem: str, break_idx: int) -> str:
    ocr_path = video_dir / f"{stem}_break{break_idx}_ocr.json"
    resolved = ocr_path.resolve()
    if resolved.is_file():
        return resolved.as_uri()
    return ""


def parse_state_files(video_dir: Path) -> list[dict]:
    """Parse all pipeline state JSON files in *video_dir* (top-level only)."""
    results: list[dict] = []
    for sf in sorted(video_dir.glob("*_pipeline_state.json")):
        if not sf.is_file():
            continue
        data = json.loads(sf.read_text())
        stem = sf.stem.replace("_pipeline_state", "")
        video_url = _video_url_from_state(data)
        ad_breaks = data.get("ad_breaks", [])
        for ab in ad_breaks:
            bi = ab.get("index", 0)
            adverts = ab.get("adverts", [])
            clip_count = ab.get("clip_count", 0)
            confidence = ab.get("confidence", {})
            conf_score = (
                confidence.get("score") if isinstance(confidence, dict) else None
            )
            conf_reasons = (
                confidence.get("reasons", []) if isinstance(confidence, dict) else []
            )

            matched = 0
            weak = 0
            estimated = 0
            unmatched = 0
            advert_details: list[dict] = []

            for a in adverts:
                det = a.get("detection") or {}
                tier = det.get("match_tier", "")

                detail = {
                    "unique_id": a.get("unique_id", ""),
                    "brand": a.get("brand", ""),
                    "category": a.get("category", ""),
                    "advertiser": a.get("advertiser", ""),
                    "duration": a.get("scheduled_duration_seconds"),
                    "tier": tier,
                    "matched_terms": det.get("matched_terms", []),
                    "last_seconds": det.get("last_seconds_clip"),
                }

                if tier in ("fallback", "advertiser", "none", "advertiser", ""):
                    weak += 1
                elif tier == "estimated":
                    estimated += 1
                elif tier:
                    matched += 1
                else:
                    unmatched += 1

                advert_details.append(detail)

            ocr_json_url = _ocr_json_url(video_dir, stem, bi)
            results.append(
                {
                    "stem": stem,
                    "break_idx": bi,
                    "ocr_json_url": ocr_json_url,
                    "adverts": len(adverts),
                    "matched": matched,
                    "weak": weak,
                    "estimated": estimated,
                    "unmatched": unmatched,
                    "clips": clip_count,
                    "confidence": conf_score,
                    "reasons": conf_reasons,
                    "advert_details": advert_details,
                    "state_file": sf.name,
                    "video_url": video_url,
                }
            )
    return results


def parse_log(log_path: Path) -> dict:
    """Parse the pipeline log for key events."""
    text = log_path.read_text()
    lines = text.splitlines()

    events: dict = {
        "warnings": [],
        "no_match_events": [],
        "anchor_events": [],
        "clamp_corrected": [],
        "clamp_skipped": [],
        "confidence_events": [],
        "unmatched_logs": [],
    }

    anchor_groups: list[dict] = []
    current_anchor: dict | None = None
    current_video: str = ""

    for line in lines:
        processing_m = re.search(r"Processing: (.+?)\.mp4", line)
        if processing_m:
            current_video = processing_m.group(1)
        if "WARNING" in line and "advert-identifier" not in line:
            events["warnings"].append(line)
        if "NO MATCH" in line:
            events["no_match_events"].append(line)

        if "running anchor re-estimation" in line:
            current_anchor = {
                "trigger": line,
                "video": current_video,
                "anchor_advert": None,
                "adverts": [],
                "result": None,
            }
            anchor_groups.append(current_anchor)

        if "confidence after anchor" in line and current_anchor is not None:
            current_anchor["result"] = line
            current_anchor = None

        if current_anchor is not None and "Anchor re-estimation: using advert" in line:
            current_anchor["anchor_advert"] = line

        if current_anchor is not None and "Anchor re-estimation: no matched" in line:
            current_anchor["anchor_advert"] = line

        if current_anchor is not None and "Anchor: advert" in line:
            current_anchor["adverts"].append(line)

        if "corrected:" in line:
            events["clamp_corrected"].append(line)
        if "Clamp skipped" in line:
            events["clamp_skipped"].append(line)
        if "Unmatched advert" in line:
            events["unmatched_logs"].append(line)

    events["anchor_groups"] = anchor_groups
    return events


# ── HTML generation ─────────────────────────────────────────────────────────


def _escape(text: str) -> str:
    return html.escape(text or "")


def _short_stem(stem: str) -> str:
    """Shorten video stem to just date+time for display."""
    parts = stem.split("_")
    if len(parts) >= 3:
        return "_".join(parts[-2:])
    return stem


def _row_class(conf: float | None) -> str:
    if conf is None:
        return "row-fail"
    if conf >= 0.8:
        return "row-pass"
    if conf >= 0.6:
        return "row-diff"
    return "row-fail"


def _conf_class(conf: float | None) -> str:
    if conf is None:
        return "status-fail"
    if conf >= 0.8:
        return "status-pass"
    if conf >= 0.6:
        return "status-diff"
    return "status-fail"


def generate_break_rows(break_data: list[dict]) -> str:
    rows = []
    for bd in break_data:
        rc = _row_class(bd["confidence"])
        cc = _conf_class(bd["confidence"])
        conf_str = f"{bd['confidence']:.3f}" if bd["confidence"] is not None else "N/A"
        issues = "; ".join(bd["reasons"]) if bd["reasons"] else ""
        vid_link = (
            f'<a href="{_escape(bd["video_url"])}" target="_blank" style="color:var(--link)">'
            f'{_escape(_short_stem(bd["stem"]))}</a>'
        )
        rows.append(
            f'<tr class="{rc}">'
            f"<td>{vid_link}</td>"
            f'<td>B{bd["break_idx"]}</td>'
            f'<td>{bd["adverts"]}</td>'
            f'<td class="status-pass">{bd["matched"]}</td>'
            f'<td class="status-diff">{bd["weak"]}</td>'
            f'<td class="status-diff">{bd["estimated"]}</td>'
            f'<td class="status-fail">{bd["unmatched"]}</td>'
            f'<td>{bd["clips"]}</td>'
            f'<td class="{cc}">{conf_str}</td>'
            f'<td style="font-size:0.8em;color:var(--fg-muted)">{_escape(issues)}</td>'
            f"</tr>"
        )
    return "\n".join(rows)


def _clip_url(video_dir: Path, unique_id: str, category: str, brand: str) -> str:
    """Build a file:// URL to the advert clip MP4 if it exists."""
    cat = _sanitize_filename(category or "unknown")
    brd = _sanitize_filename(brand or "unknown")
    clip_path = video_dir / f"{unique_id}_{cat}_{brd}.mp4"
    resolved = clip_path.resolve()
    if resolved.is_file():
        return resolved.as_uri()
    return ""


def generate_unmatched_weak_list(break_data: list[dict], video_dir: Path) -> str:
    parts: list[str] = []
    count = 0
    for bd in break_data:
        weak_adverts = [
            a
            for a in bd["advert_details"]
            if a["tier"] in WEAK_TIERS or a["tier"] == "estimated"
        ]
        if not weak_adverts:
            continue
        for a in weak_adverts:
            count += 1
            tier = a["tier"] or "none"
            terms = ", ".join(a["matched_terms"]) if a["matched_terms"] else "—"
            dur = f"{a['duration']}s" if a["duration"] else "?"
            cat = _escape(a["category"] or "?")
            uid = _escape(a["unique_id"] or "?")
            brand = _escape(a["brand"] or "?")
            vid = _escape(bd["stem"])
            bi = bd["break_idx"]

            clip_url = _clip_url(video_dir, a["unique_id"], a["category"], a["brand"])
            state_info = ""
            if bd.get("state_file"):
                state_info = f" &mdash; {_escape(bd['state_file'])}"
            clip_link = ""
            if clip_url:
                clip_link = f' &mdash; <a href="{_escape(clip_url)}" target="_blank" style="color:var(--link)">clip</a>'
            ocr_link = ""
            if bd.get("ocr_json_url"):
                ocr_link = f' &mdash; <a href="{_escape(bd["ocr_json_url"])}" target="_blank" style="color:var(--link)">OCR JSON</a>'
            parts.append(
                f'<div class="advert-entry">'
                f'<span class="brand-name">{brand}</span> '
                f'<span class="meta">({uid})</span><br>'
                f'<span class="meta">Tier: <strong>{_escape(tier)}</strong>'
                f" | Terms: {_escape(terms)}"
                f" | Duration: {dur}"
                f" | Category: {cat}</span><br>"
                f'<span class="meta" style="color:var(--fg-muted)">'
                f"{_escape(vid)} B{bi}{state_info}{clip_link}{ocr_link}</span>"
                f"</div>"
            )

    if not parts:
        return "<p>No unmatched or weak adverts.</p>"
    return "\n".join(parts)


def generate_low_conf_list(break_data: list[dict]) -> str:
    parts: list[str] = []
    count = 0
    for bd in break_data:
        if bd["confidence"] is not None and bd["confidence"] < 0.6:
            count += 1
            conf_str = f"{bd['confidence']:.3f}"
            reasons = (
                "; ".join(bd["reasons"]) if bd["reasons"] else "No specific reasons"
            )
            vid_link = (
                f'<a href="{_escape(bd["video_url"])}" target="_blank" style="color:var(--link)">'
                f'{_escape(_short_stem(bd["stem"]))}</a>'
            )
            parts.append(
                f'<div class="advert-entry">'
                f'<span class="brand-name">{vid_link} B{bd["break_idx"]}</span>'
                f' &mdash; Confidence: <strong class="status-fail">{conf_str}</strong><br>'
                f'<span class="meta">{_escape(reasons)}</span>'
                f'<br><span class="meta" style="color:var(--fg-muted)">{bd["adverts"]} adverts, '
                f'{bd["matched"]} matched, {bd["clips"]} clips</span>'
                f"</div>"
            )
    if not parts:
        return "<p>No low-confidence breaks.</p>"
    return "\n".join(parts)


def _video_url_for_stem(break_data: list[dict], stem: str) -> str:
    for bd in break_data:
        if bd["stem"] == stem:
            return bd.get("video_url", "")
    return ""


def generate_anchor_list(events: dict, break_data: list[dict]) -> str:
    groups = events.get("anchor_groups", [])
    parts: list[str] = []
    for g in groups:
        trigger = g.get("trigger", "")
        video_stem = g.get("video", "")
        anchor_advert = g.get("anchor_advert", "No matched adverts")
        result = g.get("result")
        adverts = g.get("adverts", [])
        video_url = _video_url_for_stem(break_data, video_stem)

        m = re.search(r"Break (\d+) confidence ([\d.]+)", trigger)
        bi = m.group(1) if m else "?"
        before = m.group(2) if m else "?"

        after = "?"
        if result:
            rm = re.search(r"([\d.]+) \(was ([\d.]+)\)", result)
            if rm:
                after = rm.group(1)

        vid_label = _escape(_short_stem(video_stem)) if video_stem else "?"
        vid_link = (
            f'<a href="{_escape(video_url)}" target="_blank" style="color:var(--link)">{vid_label}</a>'
            if video_url
            else vid_label
        )
        parts.append(
            f'<div class="advert-entry" style="margin-bottom:8px">'
            f'<span class="brand-name">{vid_link} B{bi}</span>'
            f' &mdash; <span class="status-diff">{before}</span>'
            f' &rarr; <span class="status-pass">{after}</span><br>'
        )

        if anchor_advert and "no matched" not in anchor_advert:
            am = re.search(r"using advert \d+ \((.+?)\) as anchor", anchor_advert)
            anchor_info = am.group(1) if am else anchor_advert
            parts.append(
                f'<span class="meta">Anchor advert: <strong>{_escape(anchor_info)}</strong></span><br>'
            )
        else:
            parts.append(
                f'<span class="meta status-fail">No matched adverts, cannot anchor</span><br>'
            )

        if adverts:
            parts.append(
                f'<span class="meta" style="font-size:0.8em">Per-advert results:</span><br>'
            )
            for adv_line in adverts:
                am2 = re.search(
                    r"Anchor: advert (\d+) \((.+?)\) (estimated|verified|preserved)",
                    adv_line,
                )
                if am2:
                    ai = am2.group(1)
                    brand = am2.group(2)
                    outcome = am2.group(3)
                    extra = ""
                    if "estimated" in outcome:
                        extra = ""
                        tm = re.search(r"estimated at ([\d.]+s)", adv_line)
                        if tm:
                            extra = f" at {tm.group(1)}"
                        if "outside OCR window" in adv_line:
                            extra += " (outside OCR window)"
                    elif "verified" in outcome:
                        tm = re.search(r"verified at frame \d+ \(([\d.]+s)\)", adv_line)
                        if tm:
                            extra = f" at {tm.group(1)}"
                    elif "preserved" in outcome:
                        extra = " (preserved from Pass 1)"
                    outcome_class = (
                        "status-pass"
                        if "verified" in outcome or "preserved" in outcome
                        else "status-diff"
                    )
                    parts.append(
                        f'<span class="meta" style="font-size:0.8em;padding-left:16px">'
                        f'Advert {ai}: <span class="{outcome_class}">{_escape(outcome)}</span>'
                        f"{_escape(extra)} &mdash; {_escape(brand)}</span><br>"
                    )

        parts.append("</div>")

    if not parts:
        return "<p>No anchor re-estimation events.</p>"
    return "\n".join(parts)


def generate_clamp_section(events: dict) -> str:
    corrected = events.get("clamp_corrected", [])
    skipped = events.get("clamp_skipped", [])
    parts: list[str] = []
    if corrected:
        parts.append("<p><strong>Corrections applied:</strong></p>")
        for line in corrected:
            parts.append(
                f'<div class="advert-entry"><code>{_escape(line)}</code></div>'
            )
    if skipped:
        parts.append("<p><strong>Skipped (insufficient majority support):</strong></p>")
        for line in skipped:
            parts.append(
                f'<div class="advert-entry"><code>{_escape(line)}</code></div>'
            )
    if not parts:
        return "<p>No clamp events.</p>"
    return "\n".join(parts)


def generate_warning_text(events: dict) -> str:
    warnings = events.get("warnings", [])
    if not warnings:
        return "No warnings."
    return "\n".join(_escape(w) for w in warnings)


# ── Recommendations ──────────────────────────────────────────────────────────


def _read_existing_overrides() -> dict[str, list[str]]:
    """Read the current _BRAND_PATTERN_OVERRIDES dict from detect.py."""
    import ast

    detect_path = (
        Path(__file__).parent.parent / "src" / "ad_break_identifier" / "detect.py"
    )
    if not detect_path.is_file():
        return {}

    tree = ast.parse(detect_path.read_text())
    for node in ast.walk(tree):
        if isinstance(node, ast.Assign):
            for target in node.targets:
                if (
                    isinstance(target, ast.Name)
                    and target.id == "_BRAND_PATTERN_OVERRIDES"
                ):
                    if isinstance(node.value, ast.Dict):
                        result: dict[str, list[str]] = {}
                        for k, v in zip(node.value.keys, node.value.values):
                            if isinstance(k, ast.Constant) and isinstance(v, ast.List):
                                key = k.value
                                items = [
                                    e.value
                                    for e in v.elts
                                    if isinstance(e, ast.Constant)
                                ]
                                result[key] = items
                        return result
    return {}


def _suggest_override_domain(stripped: str, brand: str) -> str | None:
    """Suggest an override word from a domain that relates to a brand."""
    b_clean = (
        brand.lower()
        .replace(" ", "")
        .replace(".", "")
        .replace("-", "")
        .replace("'", "")
    )
    if stripped in b_clean or b_clean in stripped:
        return stripped
    return None


def _escape_md(text: str) -> str:
    return text.replace("|", "\\|")


def generate_recommendations(
    break_data: list[dict],
    video_dir: Path,
    log_path: Path,
    output_path: Path,
) -> list[dict[str, str]]:
    """Generate per-brand OCR diagnosis and write markdown recommendations.

    Returns a list of new override candidates that were found.
    """
    from ad_break_identifier.detect import (
        build_exact_patterns,
        build_substring_patterns,
        match_ocr_text,
        _brand_variants,
        _BRAND_PATTERN_OVERRIDES as KNOWN_OVERRIDES,
    )

    existing = _read_existing_overrides()

    weak_brands: dict[str, list[dict]] = {}
    for bd in break_data:
        for a in bd["advert_details"]:
            if a["tier"] in WEAK_TIERS:
                key = a["brand"]
                if key not in weak_brands:
                    weak_brands[key] = []
                weak_brands[key].append(
                    {
                        "stem": bd["stem"],
                        "break_idx": bd["break_idx"],
                        "tier": a["tier"],
                        "category": a.get("category", ""),
                    }
                )

    new_candidates: list[dict[str, str]] = []
    override_candidates: list[dict[str, str]] = []
    coverage_gaps: list[dict[str, str]] = []
    metadata_issues: list[dict[str, str]] = []
    already_overridden: list[dict[str, str]] = []

    for brand, entries in sorted(weak_brands.items()):
        stems = set(e["stem"] for e in entries)
        bis = set(e["break_idx"] for e in entries)

        # Skip Kate Garraway
        if all("21:00" in s for s in stems):
            metadata_issues.append(
                {"brand": brand, "breaks": ", ".join(f"B{b}" for b in sorted(bis))}
            )
            continue

        # Check if already overridden
        if brand in existing or brand in KNOWN_OVERRIDES:
            already_overridden.append(
                {"brand": brand, "breaks": ", ".join(f"B{b}" for b in sorted(bis))}
            )
            continue

        # Scan OCR
        found_texts = []
        for stem in list(stems)[:3]:
            for bi in sorted(bis)[:3]:
                ocr_path = video_dir / f"{stem}_break{bi}_ocr.json"
                if not ocr_path.exists():
                    continue
                try:
                    ocr = json.loads(ocr_path.read_text())
                    frames = ocr.get("frames", [])
                    sub = build_substring_patterns(brand)
                    for f in frames[:500]:
                        text = f.get("text", "").strip()
                        if not text:
                            continue
                        lower = text.lower()
                        m, terms = match_ocr_text(text, sub)
                        words = brand.lower().split()
                        for w in words:
                            cw = w.strip(".,!?()")
                            if len(cw) >= 4 and cw in lower:
                                found_texts.append(
                                    {
                                        "frame": f["frame_index"],
                                        "ts": f["timestamp_clip"],
                                        "text": text[:120],
                                        "word": cw,
                                        "matched": m,
                                    }
                                )
                                break
                except Exception:
                    pass

        if found_texts:
            any_match = any(ft["matched"] for ft in found_texts)
            if not any_match:
                # Suggest override based on first matching word
                unique_words = sorted(set(ft["word"] for ft in found_texts))
                suggestion = unique_words[0] if unique_words else ""
                if suggestion and len(suggestion) >= 4:
                    ov = suggestion.lower().replace(" ", "")
                    override_candidates.append(
                        {
                            "brand": brand,
                            "breaks": ", ".join(f"B{b}" for b in sorted(bis)),
                            "ocr_text": found_texts[0]["text"][:80],
                            "word": ov,
                        }
                    )
                    continue
            coverage_gaps.append(
                {
                    "brand": brand,
                    "breaks": ", ".join(f"B{b}" for b in sorted(bis)),
                    "note": "timing/ordering",
                }
            )
        else:
            coverage_gaps.append(
                {
                    "brand": brand,
                    "breaks": ", ".join(f"B{b}" for b in sorted(bis)),
                    "note": "no text",
                }
            )

    # Also check domain-based candidates
    domain_pat = re.compile(
        r"\b([a-z][a-z0-9]{2,})(?:\.(?:com|co\.uk|org|net|uk))\b", re.IGNORECASE
    )
    for ocr_path in sorted(video_dir.glob("*_break*_ocr.json")):
        try:
            ocr = json.loads(ocr_path.read_text())
            frames = ocr.get("frames", [])
            for f in frames[:100]:
                text = f.get("text", "").strip().lower()
                for m in domain_pat.finditer(text):
                    domain = m.group(0)
                    stripped = m.group(1)
                    if len(stripped) < 4:
                        continue
                    for brand, entries in sorted(weak_brands.items()):
                        if brand in existing or brand in KNOWN_OVERRIDES:
                            continue
                        stripped_lower = stripped.lower()
                        brand_clean = (
                            brand.lower()
                            .replace(" ", "")
                            .replace(".", "")
                            .replace("-", "")
                            .replace("'", "")
                            .replace("&", "and")
                        )
                        if (
                            stripped_lower in brand_clean
                            or brand_clean in stripped_lower
                        ):
                            cand = {
                                "brand": brand,
                                "breaks": "",
                                "ocr_text": f"{domain}",
                                "word": stripped_lower,
                            }
                            if cand not in override_candidates:
                                override_candidates.append(cand)
        except Exception:
            pass

    # Deduplicate override candidates by brand
    seen_brands = set()
    deduped = []
    for c in override_candidates:
        if c["brand"] not in seen_brands:
            seen_brands.add(c["brand"])
            deduped.append(c)

    # Build markdown
    now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    log_name = log_path.name

    section = f"""<!-- run: {log_name} -->
## Run: {log_name} ({now})

### Configuration
Pipeline log: {log_name}

### 🟢 New Override Candidates

OCR text found but no pattern matches:

| Brand | OCR text seen | Suggested override | Status |
|-------|--------------|-------------------|--------|
"""
    if deduped:
        for c in deduped:
            section += f"| {_escape_md(c['brand'])} | `{_escape_md(c['ocr_text'][:60])}` | `{c['word']}` | `--apply` to add |\n"
        new_candidates = deduped
    else:
        section += "| *(none)* | | | |\n"

    section += f"""
### ✅ Already Overridden

| Brand | Breaks |
|-------|--------|
"""
    for a in already_overridden:
        section += f"| {_escape_md(a['brand'])} | {a['breaks']} |\n"

    section += f"""
### ⚪ Coverage Gaps (no brand text in OCR)

| Brand | Breaks | Notes |
|-------|--------|-------|
"""
    for c in coverage_gaps:
        section += (
            f"| {_escape_md(c['brand'])} | {c['breaks']} | {c.get('note', '')} |\n"
        )

    section += f"""
### 🔵 Metadata Timing Issues (21:00 programme)

| Brand | Breaks |
|-------|--------|
"""
    for m in metadata_issues:
        section += f"| {_escape_md(m['brand'])} | {m['breaks']} |\n"

    section += "\n---\n"

    # Prepend to existing file or create new
    if output_path.exists():
        existing_content = output_path.read_text()
        # Find first run marker to insert after header
        content = existing_content
        first_run = content.find("<!-- run:")
        if first_run != -1:
            header = content[:first_run].rstrip()
            rest = content[first_run:]
            content = header + "\n\n" + section + "\n" + rest
        else:
            content = section + "\n" + content
    else:
        content = f"# Advert Identifier — Recommendations\n\nAccumulated override recommendations from pipeline runs.\n\n---\n\n{section}"

    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(content)
    print(f"Recommendations written to: {output_path}")
    return new_candidates


def apply_overrides(candidates: list[dict[str, str]]) -> int:
    """Add new override candidates to _BRAND_PATTERN_OVERRIDES in detect.py.

    Returns the number of overrides applied.
    """
    import ast
    import shutil

    detect_path = (
        Path(__file__).parent.parent / "src" / "ad_break_identifier" / "detect.py"
    )
    if not detect_path.is_file():
        print(f"Error: detect.py not found at {detect_path}", file=sys.stderr)
        return 0

    source = detect_path.read_text()
    tree = ast.parse(source)

    # Find the _BRAND_PATTERN_OVERRIDES dict
    target_node = None
    for node in ast.walk(tree):
        if isinstance(node, ast.Assign):
            for target in node.targets:
                if (
                    isinstance(target, ast.Name)
                    and target.id == "_BRAND_PATTERN_OVERRIDES"
                ):
                    target_node = node
                    break

    if target_node is None or not isinstance(target_node.value, ast.Dict):
        print(
            "Error: could not find _BRAND_PATTERN_OVERRIDES dict in detect.py",
            file=sys.stderr,
        )
        return 0

    existing_dict = target_node.value
    existing_keys = set()
    for k in existing_dict.keys:
        if isinstance(k, ast.Constant):
            existing_keys.add(k.value)

    applied = 0
    for c in candidates:
        brand = c["brand"]
        word = c["word"]
        if brand in existing_keys:
            continue
        # Add new key-value pair
        existing_dict.keys.append(ast.Constant(value=brand))
        existing_dict.values.append(
            ast.List(elts=[ast.Constant(value=word)], ctx=ast.Load())
        )
        existing_keys.add(brand)
        applied += 1
        print(f"  Added: {brand} -> [{word}]")

    if applied == 0:
        print("No new overrides to apply.")
        return 0

    # Unparse back to source
    try:
        new_source = ast.unparse(tree)
    except Exception as e:
        print(f"Error unparsing AST: {e}", file=sys.stderr)
        return 0

    # Create backup
    backup = detect_path.with_suffix(".py.bak")
    shutil.copy2(detect_path, backup)
    print(f"Backup written to: {backup}")

    # Write new source
    detect_path.write_text(new_source + "\n")

    # Run black
    import subprocess

    result = subprocess.run(
        [sys.executable, "-m", "black", "--target-version", "py311", str(detect_path)],
        capture_output=True,
        text=True,
    )
    if result.returncode == 0:
        print(f"  Formatted with black")
    else:
        print(f"  Warning: black formatting failed: {result.stderr}")

    print(f"Applied {applied} override(s) to {detect_path}")
    return applied


# ── Main ────────────────────────────────────────────────────────────────────


def create_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Generate post-run analysis HTML report for the advert identifier pipeline"
    )
    parser.add_argument(
        "--video-dir",
        type=str,
        default="video",
        help="Directory containing pipeline state JSON files (default: video/)",
    )
    parser.add_argument(
        "--pipeline-log",
        type=str,
        required=True,
        help="Path to the pipeline log file",
    )
    parser.add_argument(
        "--output",
        type=str,
        default="video/pipeline_analysis.html",
        help="Output HTML path (default: video/pipeline_analysis.html)",
    )
    parser.add_argument(
        "--recommend",
        action="store_true",
        default=False,
        help="Generate pipeline_recommendations.md with per-brand OCR diagnosis",
    )
    parser.add_argument(
        "--output-recommend",
        type=str,
        default="video/pipeline_recommendations.md",
        help="Output path for recommendations markdown (default: video/pipeline_recommendations.md)",
    )
    parser.add_argument(
        "--apply",
        action="store_true",
        default=False,
        help="Auto-add new override candidates to _BRAND_PATTERN_OVERRIDES in detect.py",
    )
    return parser


def main() -> int:
    parser = create_parser()
    args = parser.parse_args()

    video_dir = Path(args.video_dir)
    log_path = Path(args.pipeline_log)
    output_path = Path(args.output)

    if not video_dir.is_dir():
        print(f"Error: video directory not found: {video_dir}", file=sys.stderr)
        return 1
    if not log_path.is_file():
        print(f"Error: pipeline log not found: {log_path}", file=sys.stderr)
        return 1

    # Parse data
    break_data = parse_state_files(video_dir)
    log_events = parse_log(log_path)

    if not break_data:
        print("Error: no pipeline state files found in", video_dir, file=sys.stderr)
        return 1

    # Compute aggregates
    total_videos = len({bd["stem"] for bd in break_data})
    total_breaks = len(break_data)
    total_adverts = sum(bd["adverts"] for bd in break_data)
    total_matched = sum(bd["matched"] for bd in break_data)
    total_weak = sum(bd["weak"] for bd in break_data)
    total_estimated = sum(bd["estimated"] for bd in break_data)
    total_unmatched = sum(bd["unmatched"] for bd in break_data)
    total_clips = sum(bd["clips"] for bd in break_data)

    confs = [bd["confidence"] for bd in break_data if bd["confidence"] is not None]
    mean_conf = sum(confs) / len(confs) if confs else 0.0

    matched_pct = total_matched / total_adverts * 100 if total_adverts else 0
    weak_pct = total_weak / total_adverts * 100 if total_adverts else 0
    estimated_pct = total_estimated / total_adverts * 100 if total_adverts else 0
    unmatched_pct = total_unmatched / total_adverts * 100 if total_adverts else 0

    total_unmatched_weak = total_weak + total_estimated + total_unmatched
    not_clipped = total_adverts - total_clips
    not_found = total_unmatched + total_weak
    low_conf_count = sum(
        1
        for bd in break_data
        if bd["confidence"] is not None and bd["confidence"] < 0.6
    )
    anchor_count = len(log_events.get("anchor_groups", []))
    clamp_count = len(log_events.get("clamp_corrected", []))
    clamp_skipped = len(log_events.get("clamp_skipped", []))
    warning_count = len(log_events.get("warnings", []))

    # Generate sections
    break_rows = generate_break_rows(break_data)
    unmatched_weak_list = generate_unmatched_weak_list(break_data, video_dir)
    low_conf_list = generate_low_conf_list(break_data)
    anchor_list = generate_anchor_list(log_events, break_data)
    clamp_list = generate_clamp_section(log_events)
    warning_text = generate_warning_text(log_events)

    # Render HTML
    html_out = HTML_TEMPLATE.format(
        generated=datetime.now().strftime("%Y-%m-%d %H:%M:%S"),
        log_name=_escape(log_path.name),
        total_videos=total_videos,
        total_breaks=total_breaks,
        total_adverts=total_adverts,
        matched_pct=matched_pct,
        weak_pct=weak_pct,
        estimated_pct=estimated_pct,
        unmatched_pct=unmatched_pct,
        total_clips=total_clips,
        not_clipped=not_clipped,
        not_found=not_found,
        mean_conf=mean_conf,
        total_unmatched_weak=total_unmatched_weak,
        low_conf_count=low_conf_count,
        anchor_count=anchor_count,
        clamp_count=clamp_count,
        clamp_skipped=clamp_skipped,
        warning_count=warning_count,
        break_rows=break_rows,
        unmatched_weak_list=unmatched_weak_list,
        low_conf_list=low_conf_list,
        anchor_list=anchor_list,
        clamp_list=clamp_list,
        warning_text=warning_text,
    )

    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(html_out)
    print(f"Analysis report written to: {output_path}")

    # Generate recommendations if requested
    new_candidates = []
    if args.recommend:
        rec_path = Path(args.output_recommend)
        new_candidates = generate_recommendations(
            break_data,
            video_dir,
            log_path,
            rec_path,
        )

    # Apply overrides if requested
    if args.apply and new_candidates:
        apply_overrides(new_candidates)

    return 0


if __name__ == "__main__":
    sys.exit(main())
